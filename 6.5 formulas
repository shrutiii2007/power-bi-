Avg Sales per Customer =
DIVIDE(                                                        ------- ye mam ka hai 
    SUM(Sales[Amount]),
    DISTINCTCOUNT(Sales[Customer])
)

Avg Sales per Customer = 
VAR TotalCustomers =
    CALCULATE(DISTINCTCOUNT('Sales Table'[Customer]), ALL('Sales Table'))         ---------- ye AI ka hai 
RETURN
DIVIDE(SUM('Sales Table'[Amount]), TotalCustomers)

