Q2 (part - 1)

Previous Year Sales = 
CALCULATE(
    SUM('Sales Table'[Amount]),
    SAMEPERIODLASTYEAR('Date'[Date])
)

Q2 (part - 2)

Total Sales = SUM('Sales Table'[Amount])


Top 5 Sales = 
CALCULATE(
    [Total Sales],
    KEEPFILTERS(
        TOPN(
            5,
            ALL('Sales Table'[Customer]),   
            [Total Sales],
            DESC
        )
    )
)

Q2 (part - 3)

New Customer Sales =
CALCULATE(
    SUM('Sales Table'[Amount]),
    'Sales Table'[IsNew] = TRUE()
)

