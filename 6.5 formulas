question :- 4 (part - 1)

Sales per Quantity =
DIVIDE(
    SUM('Sales Table'[Amount]),
    SUM('Sales Table'[Quantity])
)

question :- 4 (part - 2)

Above Avg Customer =
VAR AvgSales =
    AVERAGE('Sales Table'[Amount])
RETURN
IF(
    SUM('Sales Table'[Amount]) > AvgSales,
    "Yes",
    "No"
)

